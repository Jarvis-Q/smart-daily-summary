{
  "server": {
    "url": "${SERVER_URL}",
    "method": "POST",
    "headers": {
      "Content-Type": "application/json",
      "X-Api-Key": "${DAILY_SUMMARY_TOKEN}"
    }
  },
  "local_output_dir": "your local dir",
  "extra_git_dirs": [],
  "payload_template": {
    "workDate": "{{date}}",
    "status": "1",
    "remark": "备注信息",
    "items": "{{tasks}}"
  },
  "task_item_template": {
    "workCategory": "dev",
    "workDetail": "{{content}}",
    "workHours": "{{hours}}",
    "aiHours": "{{ai_hours}}",
    "tokenConsume": "{{token_consume}}",
    "projectId": "1800000000000000140",
    "chandaoId": "",
    "sortOrder": 1
  }
}