# 复制本文件为 .env 后填入真实值。.env 已被 .gitignore 忽略，切勿提交。
#
#   cp .env.example .env
#
# 两个变量都会被 config.json 通过 ${VAR} 语法引用：
#   server.url               <- SERVER_URL
#   server.headers.X-Api-Key <- DAILY_SUMMARY_TOKEN

# 日报上报接口地址（向团队负责人索取）
SERVER_URL=https://your-private-server.example.com/api/worklog

# 个人 API Token（每人一份，不要共用、不要外传）
DAILY_SUMMARY_TOKEN=your_personal_token_here
